DATABASE_URL=postgres://ghostpsalm:password@localhost/ghostpsalm
VAULT_PATH=./vault
BIND_ADDR=127.0.0.1:3000
TOKEN_TTL_SECS=3600
GHOSTPSALM_PASSPHRASE=change-me-long-random-string
PRIVATE_KEY_PATH=./keys/private.pem
PUBLIC_KEY_PATH=./keys/public.pem
JWT_ISSUER=ghostpsalm
JWT_AUDIENCE=ghostpsalm-api

# Notifications
# Get tokens at https://pushover.net — create an application for the app token.
PUSHOVER_ENABLED=false
PUSHOVER_TOKEN=your-pushover-app-token
PUSHOVER_USER=your-pushover-user-key
# IANA timezone — see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
SCHEDULER_TZ=Australia/Perth
# Cron expressions are in local time (SCHEDULER_TZ). Format: sec min hour dom month dow
LUNCH_REVIEW_CRON=0 30 12 * * *
EVENING_ERRANDS_CRON=0 30 17 * * *
MORNING_BRIEF_CRON=0 0 8 * * *

# Vault auto-sync — commits and pushes vault changes every N hours
VAULT_SYNC_ENABLED=true
VAULT_SYNC_CRON="0 0 */4 * * *"
